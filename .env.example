# Corporate OS - Environment Variables
# Copy to .env and fill in values

# Paths
CORP_ONEDRIVE_PATH=C:/Users/YOUR_USERNAME/OneDrive - Blue Yonder
CORP_REPO_PATH=C:/os/corporate-os

# API Keys
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GRAPH_ACCESS_TOKEN=

# Optional overrides
